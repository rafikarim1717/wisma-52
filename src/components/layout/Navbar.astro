---
const WA = 'https://wa.me/6281383667680?text=Halo%2C+saya+ingin+tanya+info+kamar+Wisma+52';

const { pathname } = Astro.url;

const links = [
  { label: 'Kamar',     href: '/kamar' },
  { label: 'Fasilitas', href: '/fasilitas' },
  { label: 'Lokasi',    href: '/lokasi' },
  { label: 'Galeri',    href: '/galeri' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---
<nav class="nav">
  <a href="/" class="nav-logo">Wisma 52</a>
  <ul class="nav-links">
    {links.map(({ label, href }) => (
      <li>
        <a href={href} class:list={{ active: isActive(href) }}>{label}</a>
      </li>
    ))}
  </ul>
  <a href={WA} target="_blank" rel="noopener noreferrer" class="nav-cta">Hubungi →</a>
</nav>
