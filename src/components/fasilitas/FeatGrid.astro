---
/**
 * FeatGrid — reusable photo grid with optional real images
 *
 * layout:
 *   'duo'  → 2 columns: left = tall main photo, right = stack of 2 square photos
 *   'trio' → masonry-style 5-photo mosaic for fasilitas bersama
 */

interface PhotoSlot {
  title: string;
  sub?: string;
  color: string;
  src?: string;
  aspect?: 'tall' | 'square' | 'free' | 'wide';
  titleSm?: boolean;
  minHeight?: number;
}

interface Props {
  layout: 'duo' | 'trio';
  main: PhotoSlot;
  stack: PhotoSlot[];
}

const { layout, main, stack } = Astro.props;

const blockClass = layout === 'trio' ? 'feat-block trio' : 'feat-block';
const mainAspect = main.aspect ?? (layout === 'duo' ? 'tall' : 'free');
---

{layout === 'trio' ? (
  <>
    <div class="fasilitas-mosaic">
      <div class="mosaic-item mosaic-tall" data-index="0">
        <img src="/images/fasilitas/dapur-1.webp" alt="Dapur per lantai" width="600" height="800" loading="lazy" />
        <div class="mosaic-label">Dapur per lantai</div>
      </div>
      <div class="mosaic-item mosaic-sm" data-index="1">
        <img src="/images/fasilitas/musholla.webp" alt="Musholla" width="600" height="400" loading="lazy" />
        <div class="mosaic-label">Musholla</div>
      </div>
      <div class="mosaic-item mosaic-sm" data-index="2">
        <img src="/images/fasilitas/ruang-tv.webp" alt="Ruang TV" width="600" height="400" loading="lazy" />
        <div class="mosaic-label">Ruang TV</div>
      </div>
      <div class="mosaic-bottom-row">
        <div class="mosaic-item mosaic-xs" data-index="3">
          <img src="/images/fasilitas/lorong.webp" alt="Lorong" width="400" height="300" loading="lazy" />
          <div class="mosaic-label">Lorong</div>
        </div>
        <div class="mosaic-item mosaic-wide" data-index="4">
          <img src="/images/fasilitas/dapur-2.webp" alt="Dapur 2" width="800" height="500" loading="lazy" />
          <div class="mosaic-label">Dapur 2</div>
        </div>
      </div>
    </div>

    <!-- Fasilitas lightbox -->
    <div id="fasilitas-lightbox" class="lightbox" aria-hidden="true">
      <button class="lightbox-close" id="fas-lb-close" aria-label="Tutup">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
      <div class="lightbox-backdrop" id="fas-lb-backdrop"></div>
      <div class="lightbox-content" style="position:relative;z-index:1">
        <button id="fas-lb-prev"
          style="position:fixed;left:20px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.15);border:none;color:#fff;width:44px;height:44px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:2">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </button>
        <img id="fas-lb-img" src="" alt=""
          style="max-width:88vw;max-height:82vh;object-fit:contain;display:block;position:relative;z-index:1"/>
        <button id="fas-lb-next"
          style="position:fixed;right:20px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.15);border:none;color:#fff;width:44px;height:44px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:2">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
        <div style="text-align:center;margin-top:14px;position:relative;z-index:1">
          <p id="fas-lb-caption" style="color:rgba(255,255,255,0.7);font-size:13px;margin-bottom:4px"></p>
          <p id="fas-lb-counter" style="color:rgba(255,255,255,0.4);font-size:12px"></p>
        </div>
        <div id="fas-lb-thumbs"
          style="display:flex;gap:8px;margin-top:14px;position:relative;z-index:1;justify-content:center"></div>
      </div>
    </div>

    <script>
      type Photo = { src: string; alt: string }

      const photos: Photo[] = [
        { src: '/images/fasilitas/dapur-1.webp', alt: 'Dapur per lantai' },
        { src: '/images/fasilitas/musholla.webp', alt: 'Musholla' },
        { src: '/images/fasilitas/ruang-tv.webp', alt: 'Ruang TV bersama' },
        { src: '/images/fasilitas/lorong.webp', alt: 'Lorong kamar' },
        { src: '/images/fasilitas/dapur-2.webp', alt: 'Dapur — sudut lain' },
      ]

      const lb = document.getElementById('fasilitas-lightbox')
      const lbImg = document.getElementById('fas-lb-img') as HTMLImageElement | null
      const lbCaption = document.getElementById('fas-lb-caption')
      const lbCounter = document.getElementById('fas-lb-counter')
      const lbThumbs = document.getElementById('fas-lb-thumbs')
      const lbPrev = document.getElementById('fas-lb-prev')
      const lbNext = document.getElementById('fas-lb-next')
      const lbClose = document.getElementById('fas-lb-close')
      const lbBackdrop = document.getElementById('fas-lb-backdrop')

      let current = 0

      function goTo(index: number) {
        current = Math.max(0, Math.min(index, photos.length - 1))
        const p = photos[current]
        if (lbImg) { lbImg.src = p.src; lbImg.alt = p.alt }
        if (lbCaption) lbCaption.textContent = p.alt
        if (lbCounter) lbCounter.textContent = `${current + 1} / ${photos.length}`
        if (lbPrev) (lbPrev as HTMLButtonElement).style.opacity = current === 0 ? '0.3' : '1'
        if (lbNext) (lbNext as HTMLButtonElement).style.opacity =
          current === photos.length - 1 ? '0.3' : '1'
        document.querySelectorAll<HTMLImageElement>('#fas-lb-thumbs img')
          .forEach((t, i) => {
            t.style.opacity = i === current ? '1' : '0.5'
            t.style.border = i === current ? '2px solid #fff' : '2px solid transparent'
          })
      }

      function openAt(index: number) {
        if (!lb) return
        if (lbThumbs) {
          lbThumbs.innerHTML = ''
          photos.forEach((p, i) => {
            const thumb = document.createElement('img')
            thumb.src = p.src
            thumb.alt = p.alt
            thumb.style.cssText =
              'width:48px;height:36px;object-fit:cover;cursor:pointer;transition:opacity 0.2s'
            thumb.addEventListener('click', () => goTo(i))
            lbThumbs.appendChild(thumb)
          })
        }
        goTo(index)
        lb.classList.add('open')
        lb.setAttribute('aria-hidden', 'false')
        document.body.style.overflow = 'hidden'
      }

      const close = () => {
        lb?.classList.remove('open')
        lb?.setAttribute('aria-hidden', 'true')
        document.body.style.overflow = ''
      }

      lbPrev?.addEventListener('click', () => goTo(current - 1))
      lbNext?.addEventListener('click', () => goTo(current + 1))
      lbClose?.addEventListener('click', close)
      lbBackdrop?.addEventListener('click', close)
      document.addEventListener('keydown', e => {
        if (!lb?.classList.contains('open')) return
        if (e.key === 'ArrowLeft') goTo(current - 1)
        if (e.key === 'ArrowRight') goTo(current + 1)
        if (e.key === 'Escape') close()
      })

      document.querySelectorAll<HTMLElement>('.mosaic-item').forEach((item, i) => {
        item.addEventListener('click', () => openAt(i))
      })
    </script>
  </>
) : (
  <div class={blockClass} style="margin-bottom:16px">
    <!-- Main photo slot -->
    <div
      class:list={['feat-img', mainAspect]}
      style={`background:${main.color};${main.minHeight ? `min-height:${main.minHeight}px;` : ''}`}
    >
      {main.src && (
        <img
          src={main.src}
          alt={main.title}
          style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block"
          loading="lazy"
        />
      )}
      <div class="feat-img-inner" style={main.src ? 'position:relative;z-index:1' : undefined}>
        <div class:list={['feat-img-title', { sm: main.titleSm }]}>{main.title}</div>
        {main.sub && <div class="feat-img-sub">{main.sub}</div>}
      </div>
    </div>

    <!-- Stacked photo slots -->
    <div class="feat-block-stack">
      {stack.map((slot) => (
        <div
          class:list={['feat-img', slot.aspect ?? 'free']}
          style={`background:${slot.color};${slot.minHeight ? `min-height:${slot.minHeight}px;` : ''}`}
        >
          {slot.src && (
            <img
              src={slot.src}
              alt={slot.title}
              style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block"
              loading="lazy"
            />
          )}
          <div class="feat-img-inner" style={slot.src ? 'position:relative;z-index:1' : undefined}>
            <div class:list={['feat-img-title', { sm: slot.titleSm }]}>{slot.title}</div>
            {slot.sub && <div class="feat-img-sub">{slot.sub}</div>}
          </div>
        </div>
      ))}
    </div>
  </div>
)}
