---
const items = [
  {
    name: 'Listrik',
    note: 'Tanpa batas wajar',
    icon: '<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>',
  },
  {
    name: 'WiFi kencang',
    note: 'Semua lantai',
    icon: '<path d="M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01"/>',
  },
  {
    name: 'Parkir gratis',
    note: 'Mobil & motor',
    icon: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>',
  },
  {
    name: 'House-keeping',
    note: 'Setiap minggu',
    icon: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  },
  {
    name: 'Keamanan 24 jam',
    note: 'CCTV & petugas',
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  },
  {
    name: 'Dapur bersama',
    note: 'Per lantai',
    icon: '<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>',
  },
];
---
<div class="incl-section">
  <p class="tipe-label">Semua sudah termasuk</p>
  <div class="incl-grid">
    {items.map((item) => (
      <div class="incl-item">
        <div class="incl-icon">
          <svg viewBox="0 0 24 24">
            <Fragment set:html={item.icon} />
          </svg>
        </div>
        <div class="incl-name">{item.name}</div>
        <div class="incl-note">{item.note}</div>
      </div>
    ))}
  </div>
</div>
