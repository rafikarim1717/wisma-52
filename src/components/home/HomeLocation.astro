---
const GMAPS = 'https://maps.app.goo.gl/wisma52kramat'; // ganti dengan link Maps aktual
---
<section class="section">
  <p class="section-label">Lokasi</p>
  <div class="location-grid">
    <!-- Map placeholder — ganti dengan <iframe> Google Maps saat siap -->
    <a href={GMAPS} target="_blank" rel="noopener noreferrer" class="map-placeholder">
      <div class="map-txt">
        Jl. Kramat 5 No.2<br />
        Senen, Jakarta Pusat<br /><br />
        Buka Google Maps
      </div>
    </a>

    <div class="location-list">
      <span class="loc-category">Transportasi</span>
      <div class="loc-item">
        <span class="loc-name">Halte Busway Kramat</span>
        <span class="loc-dist">400 m · 5 mnt jalan</span>
      </div>
      <div class="loc-item">
        <span class="loc-name">Stasiun Cikini</span>
        <span class="loc-dist">1,2 km · 5 mnt ojol</span>
      </div>
      <div class="loc-item">
        <span class="loc-name">Stasiun Senen</span>
        <span class="loc-dist">1,5 km · 7 mnt ojol</span>
      </div>

      <span class="loc-category loc-category-mt">Tempat kerja &amp; studi</span>
      <div class="loc-item">
        <span class="loc-name">Pertamina Pusat</span>
        <span class="loc-dist">1,8 km</span>
      </div>
      <div class="loc-item">
        <span class="loc-name">RS Cipto Mangunkusumo</span>
        <span class="loc-dist">2 km</span>
      </div>
      <div class="loc-item">
        <span class="loc-name">UI Salemba</span>
        <span class="loc-dist">1,5 km</span>
      </div>
    </div>
  </div>
</section>
