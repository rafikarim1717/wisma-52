---
const GMAPS = 'https://maps.app.goo.gl/wisma52kramat';
---
<div class="section-full section-cream" style="border-bottom:0.5px solid #e2e0d8">
  <div class="container">
    <section class="section">
      <p class="section-label">Lokasi</p>
      <div class="location-grid">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3966.521260322323!2d106.84455!3d-6.196!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e69f3e945e7c5ab%3A0x4a01c87a9d6c0a5e!2sJl.+Kramat+5+No.2%2C+Senen%2C+Jakarta+Pusat!5e0!3m2!1sid!2sid!4v1700000000000"
          width="100%"
          height="100%"
          style="border:0;display:block;width:100%;aspect-ratio:4/3;min-height:300px"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Lokasi Wisma 52 — Jl. Kramat 5 No.2, Senen, Jakarta Pusat"
        ></iframe>

        <div class="location-list">
          <span class="loc-category">Transportasi</span>
