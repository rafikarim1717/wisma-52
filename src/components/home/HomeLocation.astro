          <div class="loc-item">
            <span class="loc-name">Stasiun Cikini</span>
            <span class="loc-dist">1,2 km · 5 mnt gojek</span>
          </div>
          <div class="loc-item">
            <span class="loc-name">Stasiun Senen</span>
            <span class="loc-dist">1,5 km · 7 mnt gojek</span>
          </div>

          <span class="loc-category loc-category-mt">Tempat kerja &amp; studi</span>
          <div class="loc-item">
            <span class="loc-name">Kantor Pegadaian Pusat</span>
            <span class="loc-dist">500 m</span>
          </div>
          <div class="loc-item">
            <span class="loc-name">PT Pertamina Regional JBB</span>
            <span class="loc-dist">1 km</span>
          </div>
          <div class="loc-item">
            <span class="loc-name">UI Salemba</span>
            <span class="loc-dist">1,5 km</span>
