---
const MAPS_SRC = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3966.521260322323!2d106.84455!3d-6.196!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e69f3e945e7c5ab%3A0x4a01c87a9d6c0a5e!2sJl.+Kramat+5+No.2%2C+Senen%2C+Jakarta+Pusat!5e0!3m2!1sid!2sid!4v1700000000000";
// MAPS_SRC is passed to the button via data-src; the iframe is injected only on click
---
<div class="section-full section-cream" style="border-bottom:0.5px solid #e2e0d8">
  <div class="container">
    <section class="section">
      <p class="section-label">Lokasi</p>
      <div class="location-grid">
        <div id="maps-facade-wrap" style="position:relative;aspect-ratio:4/3;min-height:300px;background:#e8e6de;display:flex;align-items:center;justify-content:center;overflow:hidden">
          <img
            src="/images/eksterior/halaman-parkir.webp"
            alt="Wisma 52 — Jl. Kramat 5 No.2, Senen, Jakarta Pusat"
            width="800" height="600"
            loading="lazy"
            style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.35"
          />
          <div style="position:relative;z-index:1;text-align:center">
            <p style="font-family:'DM Sans',sans-serif;font-size:13px;color:#1a1a18;margin:0 0 12px;font-weight:500">Jl. Kramat 5 No.2, Senen, Jakarta Pusat</p>
            <button id="maps-load-btn" data-src={MAPS_SRC}
              style="font-family:'DM Sans',sans-serif;font-size:13px;background:#1a1a18;color:#fff;border:none;padding:9px 20px;cursor:pointer;letter-spacing:0.3px">
              Tampilkan peta
            </button>
          </div>
        </div>

        <div class="location-list">
  <span class="loc-category">Transportasi</span>
  <div class="loc-item">
    <span class="loc-name">Halte Busway Kramat Sentiong</span>
    <span class="loc-dist">350 m · 4 mnt jalan</span>
  </div>
  <div class="loc-item">
    <span class="loc-name">Stasiun Cikini</span>
    <span class="loc-dist">1,2 km · 5 mnt gojek</span>
  </div>
  <div class="loc-item">
    <span class="loc-name">Stasiun Pasar Senen</span>
    <span class="loc-dist">1,5 km · 7 mnt gojek</span>
  </div>

  <span class="loc-category loc-category-mt">Tempat Kerja & Studi</span>
  <div class="loc-item">
    <span class="loc-name">Kantor Pusat PT Pegadaian</span>
    <span class="loc-dist">450 m · 5   mnt jalan</span>
  </div>
  <div class="loc-item">
    <span class="loc-name">KPP Pratama Jakarta Senen</span>
    <span class="loc-dist">150 m · 2 mnt jalan</span>
  </div>
  <div class="loc-item">
    <span class="loc-name">UI Kampus Salemba</span>
    <span class="loc-dist">1,0 km · 4 mnt gojek</span>
  </div>
  <div class="loc-item">
    <span class="loc-name">RS St. Carolus / RSCM</span>
    <span class="loc-dist">1,2 km · 5 mnt gojek</span>
  </div>
</div>
      </div>
    </section>
  </div>
</div>

<script>
  const btn = document.getElementById('maps-load-btn') as HTMLButtonElement | null
  const wrap = document.getElementById('maps-facade-wrap')
  btn?.addEventListener('click', () => {
    const src = btn.dataset.src
    if (!src || !wrap) return
    const iframe = document.createElement('iframe')
    iframe.src = src
    iframe.title = 'Lokasi Wisma 52 — Jl. Kramat 5 No.2, Senen, Jakarta Pusat'
    iframe.width = '100%'
    iframe.height = '100%'
    iframe.style.cssText = 'border:0;display:block;width:100%;height:100%;position:absolute;inset:0'
    iframe.allowFullscreen = true
    iframe.setAttribute('referrerpolicy', 'no-referrer-when-downgrade')
    wrap.innerHTML = ''
    wrap.style.padding = '0'
    wrap.appendChild(iframe)
  }, { once: true })
</script>
