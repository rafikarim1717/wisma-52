---
const WA = 'https://wa.me/6281383667680?text=Halo%2C+saya+mau+cek+ketersediaan+kamar+Wisma+52';
---
<section class="hero">
  <p class="hero-eyebrow">Kramat Raya · Jakarta Pusat</p>
  <h1 class="hero-title serif">Tinggal nyaman,<br><em>tanpa drama.</em></h1>
  <p class="hero-sub">
    Kosan eksklusif untuk profesional muda, karyawan, dan mahasiswa.
    Fasilitas lengkap, lokasi strategis, dikelola serius.
  </p>
  <div class="hero-actions">
    <a href={WA} target="_blank" rel="noopener noreferrer" class="btn-primary">
      Cek ketersediaan
    </a>
    <a href="/kamar" class="btn-secondary">Lihat kamar</a>
  </div>
  <div class="hero-meta">
    <div class="meta-item">
      <div class="meta-num serif">23</div>
      <div class="meta-label">Total kamar</div>
    </div>
    <div class="meta-item">
      <div class="meta-num serif">2</div>
      <div class="meta-label">Tipe kamar</div>
    </div>
    <div class="meta-item">
      <div class="meta-num serif">24/7</div>
      <div class="meta-label">Keamanan</div>
    </div>
    <div class="meta-item">
      <div class="meta-num serif">400m</div>
      <div class="meta-label">Ke busway</div>
    </div>
  </div>
</section>
