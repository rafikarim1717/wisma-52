---
const faqs = [
  {
    q: 'Apakah harga sewa sudah benar-benar bersih (all-in)?',
    a: 'Benar. Harga sudah termasuk listrik, air, Wi-Fi kencang, dan parkir gratis. Tidak ada biaya tambahan lagi setiap bulannya.',
  },
  {
    q: 'Apakah bebas akses keluar masuk 24 jam?',
    a: 'Ya, setiap penghuni diberikan akses kunci mandiri sehingga bebas keluar masuk kapan saja tanpa jam malam.',
  },
  {
    q: 'Apakah kamar bisa dihuni berdua?',
    a: 'Kamar kami dirancang khusus untuk hunian satu orang (single) demi menjaga kenyamanan dan ketenangan seluruh penghuni.',
  },
  {
    q: 'Bagaimana aturan untuk tamu yang berkunjung?',
    a: 'Tamu diperbolehkan berkunjung di area penerima tamu. Untuk kunjungan ke dalam kamar, berlaku batas waktu hingga pukul 22.00 WIB.',
  },
  {
    q: 'Bagaimana prosedur booking dan survei?',
    a: 'Silakan hubungi admin via WhatsApp untuk cek ketersediaan. Booking dianggap sah setelah melakukan survei lokasi dan pembayaran DP.',
  },
  {
  q: 'Apa bedanya kamar lantai 1-3 dengan promo lantai 4?',
  a: 'Kamar lantai 4 memiliki fasilitas yang sama namun dengan harga lebih ekonomis (mulai 2,4jt). Cocok untuk Anda yang mencari opsi lebih hemat.',
},
];
---
<div class="section-full section-cream" style="border-bottom:0.5px solid #e2e0d8">
  <div class="container">
    <section class="section">
      <p class="section-label">Pertanyaan umum</p>
      <div class="faq-list">
        {faqs.map((item) => (
          <div class="faq-item">
            <button class="faq-trigger" aria-expanded="false">
              <span class="faq-q">{item.q}</span>
              <span class="faq-arrow">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="1.5"
                  stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </span>
            </button>
            <div class="faq-body" hidden>
              <div class="faq-a">{item.a}</div>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</div>

<script>
  document.querySelectorAll('.faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const body = trigger.nextElementSibling as HTMLElement
      const isOpen = trigger.getAttribute('aria-expanded') === 'true'

      if (isOpen) {
        const height = body.scrollHeight
        body.style.height = height + 'px'
        body.classList.add('animating')
        body.removeAttribute('hidden')

        requestAnimationFrame(() => {
          body.style.transition = 'height 0.25s ease'
          body.style.height = '0px'
        })

        body.addEventListener('transitionend', () => {
          body.style.height = ''
          body.style.transition = ''
          body.classList.remove('animating')
          body.setAttribute('hidden', '')
          trigger.setAttribute('aria-expanded', 'false')
        }, { once: true })

      } else {
        body.classList.add('animating')
        body.removeAttribute('hidden')
        const height = body.scrollHeight
        body.style.height = '0px'

        requestAnimationFrame(() => {
          body.style.transition = 'height 0.25s ease'
          body.style.height = height + 'px'
        })

        body.addEventListener('transitionend', () => {
          body.style.height = ''
          body.style.transition = ''
          body.classList.remove('animating')
          trigger.setAttribute('aria-expanded', 'true')
        }, { once: true })
      }
    })
  })
</script>
