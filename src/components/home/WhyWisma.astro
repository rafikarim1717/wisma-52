  },
  {
    num: '02',
    title: 'Harga sudah termasuk semua',
    desc: 'Listrik, air, Wi-Fi, house-keeping mingguan. Tidak ada biaya tersembunyi di akhir bulan.',
  },
  {
    num: '03',
    title: 'Kamar mandi dalam, bukan bersama',
