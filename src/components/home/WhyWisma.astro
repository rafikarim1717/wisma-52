---
<div class="section-full section-cream" style="border-bottom:0.5px solid #e2e0d8">
  <div class="container">
    <section class="section">
      <p class="section-label">Kenapa Wisma 52</p>
      <div class="usp-grid">
        {usps.map((u) => (
          <div class="usp-item">
            <div class="usp-num serif">{u.num}</div>
            <div class="usp-title">{u.title}</div>
            <div class="usp-desc">{u.desc}</div>
          </div>
        ))}
      </div>
    </section>
  </div>
</div>
