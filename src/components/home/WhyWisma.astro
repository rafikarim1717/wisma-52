---
const usps = [
{
  num: '01',
  title: 'Lokasi Strategis di Pusat Kota',
  desc: 'Jalan kaki ke Pegadaian, KPP Pratama, dan Komisi Yudisial. Menit ke UI Salemba, RSCM, dan RS Carolus.',
},
{
  num: '02',
  title: 'Harga All-In, Tanpa Biaya Ekstra',
  desc: 'Listrik, air, dan WiFi sudah termasuk. Tidak ada tagihan kejutan di akhir bulan.',
},
{
  num: '03',
  title: 'Kamar Mandi Dalam & Privat',
  desc: 'Shower, water heater, dan kloset duduk di dalam kamar. Bukan kamar mandi bersama.',
},
  {
    num: '04',
    title: 'Parkir gratis — mobil maupun motor',
    desc: 'Fasilitas parkir yang langka di Jakarta Pusat, tersedia tanpa biaya tambahan.',
  },
];
---
<div class="section-full section-cream" style="border-bottom:0.5px solid #e2e0d8">
  <div class="container">
    <section class="section">
      <p class="section-label">Kenapa Wisma 52</p>
      <div class="usp-grid">
        {usps.map((u) => (
          <div class="usp-item">
            <div class="usp-num serif">{u.num}</div>
            <div class="usp-title">{u.title}</div>
            <div class="usp-desc">{u.desc}</div>
          </div>
        ))}
      </div>
    </section>
  </div>
</div>
