---
const usps = [
{
  num: '01',
  title: 'Lokasi Strategis di Pusat Kota',
  desc: 'Cukup jalan kaki ke Kantor Pusat Pegadaian, KPP Pratama, dan Komisi Yudisial. Hanya hitungan menit ke UI Salemba, RS Carolus & RSCM.',
},
{
  num: '02',
  title: 'Harga All-In, Tanpa Biaya Ekstra',
  desc: 'Sudah termasuk listrik, air, dan Wi-Fi. Nikmati kenyamanan tinggal tanpa pusing memikirkan tagihan tambahan di akhir bulan.',
},
  {
  num: '03',
  title: 'Kamar Mandi Dalam & Privat',
  desc: 'Bukan kamar mandi bersama. Lengkap dengan shower, water heater, dan kloset duduk untuk kenyamanan maksimal Anda.',
},
  {
    num: '04',
    title: 'Parkir gratis — mobil maupun motor',
    desc: 'Fasilitas parkir yang langka di Jakarta Pusat, tersedia tanpa biaya tambahan.',
  },
