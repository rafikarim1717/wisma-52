      ))}
    </div>
    <div class="pg-row pg-row-3">
      {[fasilitasPhotos[2], fasilitasPhotos[3], fasilitasPhotos[4]].map(p => (
        <div class="ph" style={`background:${p.bgColor}`}
          data-kategori="fasilitas" data-src={p.src ?? ''} data-alt={p.name}>
          {p.src && <img src={p.src} alt={p.name} style={imgStyle} loading="lazy" />}
          <div class="ph-label">
