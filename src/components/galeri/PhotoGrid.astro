---
import photos from '../../content/galeri/photos.json';

type Photo = typeof photos[number] & { src?: string };

const deluxePhotos    = photos.filter(p => p.kategori === 'deluxe')    as Photo[];
const standardPhotos  = photos.filter(p => p.kategori === 'standard')  as Photo[];
const fasilitasPhotos = photos.filter(p => p.kategori === 'fasilitas') as Photo[];
const eksteriorPhotos = photos.filter(p => p.kategori === 'eksterior') as Photo[];
const totalCount = photos.length;

const imgStyle = "position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block";
---

<!-- Kamar Deluxe section: 7 photos → 2a | 3 | 2b -->
<div class="cat-section section-full section-cream" data-section="deluxe" style="border-bottom:0.5px solid #e2e0d8">
  <div class="container">
    <div class="cat-header">
      <div class="cat-title serif">Kamar Deluxe</div>
      <div class="cat-desc">4 × 5 m · AC · kamar mandi dalam · water heater · TV · meja kerja</div>
    </div>
  </div>
  <div class="container" style="padding-bottom:28px">
    <div class="pg-row pg-row-2a">
      {[deluxePhotos[0], deluxePhotos[1]].map(p => (
        <div class="ph" style={`background:${p.bgColor}`}
          data-kategori="deluxe" data-src={p.src ?? ''} data-alt={p.name}>
          {p.src && <img src={p.src} alt={p.name} style={imgStyle} loading="lazy" />}
          <div class="ph-label">
            <div class="ph-name">{p.name}</div>
            {p.sub && <div class="ph-sub">{p.sub}</div>}
          </div>
        </div>
      ))}
    </div>
    <div class="pg-row pg-row-3">
      {[deluxePhotos[2], deluxePhotos[3], deluxePhotos[4]].map(p => (
        <div class="ph" style={`background:${p.bgColor}`}
          data-kategori="deluxe" data-src={p.src ?? ''} data-alt={p.name}>
          {p.src && <img src={p.src} alt={p.name} style={imgStyle} loading="lazy" />}
          <div class="ph-label">
            <div class="ph-name">{p.name}</div>
            {p.sub && <div class="ph-sub">{p.sub}</div>}
          </div>
        </div>
      ))}
    </div>
    <div class="pg-row pg-row-2b">
      {[deluxePhotos[5], deluxePhotos[6]].filter(Boolean).map(p => (
        <div class="ph" style={`background:${p.bgColor}`}
          data-kategori="deluxe" data-src={p.src ?? ''} data-alt={p.name}>
          {p.src && <img src={p.src} alt={p.name} style={imgStyle} loading="lazy" />}
          <div class="ph-label">
            <div class="ph-name">{p.name}</div>
            {p.sub && <div class="ph-sub">{p.sub}</div>}
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- Kamar Standard section: 6 photos → 2b | 3 | 1 -->
<div class="cat-section section-full section-cream" data-section="standard" style="border-bottom:0.5px solid #e2e0d8">
  <div class="container">
    <div class="cat-header">
      <div class="cat-title serif">Kamar Standard</div>
      <div class="cat-desc">4 × 4 m · AC · kamar mandi dalam · water heater · TV · jendela ventilasi</div>
    </div>
  </div>
  <div class="container" style="padding-bottom:28px">
    <div class="pg-row pg-row-2b">
      {[standardPhotos[0], standardPhotos[1]].map(p => (
        <div class="ph" style={`background:${p.bgColor}`}
          data-kategori="standard" data-src={p.src ?? ''} data-alt={p.name}>
          {p.src && <img src={p.src} alt={p.name} style={imgStyle} loading="lazy" />}
          <div class="ph-label">
            <div class="ph-name">{p.name}</div>
            {p.sub && <div class="ph-sub">{p.sub}</div>}
          </div>
        </div>
      ))}
    </div>
    <div class="pg-row pg-row-2a">
      {[standardPhotos[2], standardPhotos[3]].map(p => (
        <div class="ph" style={`background:${p.bgColor}`}
          data-kategori="standard" data-src={p.src ?? ''} data-alt={p.name}>
          {p.src && <img src={p.src} alt={p.name} style={imgStyle} loading="lazy" />}
          <div class="ph-label">
            <div class="ph-name">{p.name}</div>
            {p.sub && <div class="ph-sub">{p.sub}</div>}
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- Tip strip -->
<div class="section-full section-light" style="border-bottom:0.5px solid #e2e0d8">
  <div class="container">
    <div class="tip-strip">
      <div class="tip-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <div class="tip-text">
        <strong>Soal foto</strong> — semua foto diambil dengan pencahayaan alami, tanpa filter atau
        wide-angle berlebihan. Ukuran kamar yang lo lihat adalah ukuran yang lo dapat.
      </div>
    </div>
  </div>
</div>

<!-- Fasilitas bersama section: 5 photos → 2a | 3 -->
