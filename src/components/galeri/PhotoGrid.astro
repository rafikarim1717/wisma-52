<!-- Photo count bar -->
<div class="section-full section-white" style="border-top:0.5px solid #e2e0d8;border-bottom:0.5px solid #e2e0d8">
  <div class="container">
    <div class="photo-count-bar">
      <span class="count-txt">Menampilkan {totalCount} foto · diperbarui 27 April 2026</span>
      <a
        href="https://wa.me/6281383667680?text=Halo%2C+boleh+minta+foto+terbaru+kamar+Wisma52%3F"
        class="btn-req"
        target="_blank"
        rel="noopener noreferrer"
      >Minta foto terbaru</a>
    </div>
  </div>
</div>

<!-- Gallery lightbox -->
<div id="gallery-lightbox" class="lightbox" aria-hidden="true">
  <button class="lightbox-close" id="gal-lb-close" aria-label="Tutup">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
      stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>
  <div class="lightbox-backdrop" id="gal-lb-backdrop"></div>
  <div class="lightbox-content" style="position:relative;z-index:1">
    <button id="gal-lb-prev"
      style="position:fixed;left:20px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.15);border:none;color:#fff;width:44px;height:44px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:2">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
    <img id="gal-lb-img" src="" alt=""
      style="max-width:88vw;max-height:82vh;object-fit:contain;display:block;position:relative;z-index:1"/>
    <button id="gal-lb-next"
      style="position:fixed;right:20px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.15);border:none;color:#fff;width:44px;height:44px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:2">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
    <div style="text-align:center;margin-top:14px;position:relative;z-index:1">
      <p id="gal-lb-caption" style="color:rgba(255,255,255,0.7);font-size:13px;margin-bottom:4px"></p>
      <p id="gal-lb-counter" style="color:rgba(255,255,255,0.4);font-size:12px"></p>
    </div>
    <div id="gal-lb-thumbs"
      style="display:flex;gap:8px;margin-top:14px;position:relative;z-index:1;justify-content:center"></div>
  </div>
</div>

<script>
  type Photo = { src: string; alt: string }

  const lb        = document.getElementById('gallery-lightbox')
  const lbImg     = document.getElementById('gal-lb-img') as HTMLImageElement | null
  const lbCaption = document.getElementById('gal-lb-caption')
  const lbCounter = document.getElementById('gal-lb-counter')
  const lbThumbs  = document.getElementById('gal-lb-thumbs')
  const lbPrev    = document.getElementById('gal-lb-prev') as HTMLButtonElement | null
  const lbNext    = document.getElementById('gal-lb-next') as HTMLButtonElement | null
  const lbClose   = document.getElementById('gal-lb-close')
  const lbBackdrop = document.getElementById('gal-lb-backdrop')

  let photos: Photo[] = []
  let current = 0

  function goTo(index: number) {
    current = Math.max(0, Math.min(index, photos.length - 1))
    const p = photos[current]
    if (lbImg) { lbImg.src = p.src; lbImg.alt = p.alt }
    if (lbCaption) lbCaption.textContent = p.alt
    if (lbCounter) lbCounter.textContent = `${current + 1} / ${photos.length}`
    if (lbPrev) lbPrev.style.opacity = current === 0 ? '0.3' : '1'
    if (lbNext) lbNext.style.opacity = current === photos.length - 1 ? '0.3' : '1'
    document.querySelectorAll<HTMLImageElement>('#gal-lb-thumbs img').forEach((t, i) => {
      t.style.opacity = i === current ? '1' : '0.5'
      t.style.border = i === current ? '2px solid #fff' : '2px solid transparent'
    })
  }

  function openAt(photoList: Photo[], index: number) {
    if (!lb) return
    photos = photoList
    if (lbThumbs) {
      lbThumbs.innerHTML = ''
      photos.forEach((p, i) => {
        const thumb = document.createElement('img')
        thumb.src = p.src
        thumb.alt = p.alt
        thumb.style.cssText = 'width:48px;height:36px;object-fit:cover;cursor:pointer;transition:opacity 0.2s'
        thumb.addEventListener('click', () => goTo(i))
        lbThumbs.appendChild(thumb)
      })
    }
    goTo(index)
    lb.classList.add('open')
    lb.setAttribute('aria-hidden', 'false')
    document.body.style.overflow = 'hidden'
  }

  const close = () => {
    lb?.classList.remove('open')
    lb?.setAttribute('aria-hidden', 'true')
    document.body.style.overflow = ''
    photos = []
  }

  lbPrev?.addEventListener('click', () => goTo(current - 1))
  lbNext?.addEventListener('click', () => goTo(current + 1))
  lbClose?.addEventListener('click', close)
  lbBackdrop?.addEventListener('click', close)
  document.addEventListener('keydown', e => {
    if (!lb?.classList.contains('open')) return
    if (e.key === 'ArrowLeft') goTo(current - 1)
    if (e.key === 'ArrowRight') goTo(current + 1)
    if (e.key === 'Escape') close()
  })

  document.querySelectorAll<HTMLElement>('.ph').forEach(el => {
    el.addEventListener('click', () => {
      const src = el.dataset.src
      if (!src) return

      const kategori = el.dataset.kategori!
      const siblings = Array.from(
        document.querySelectorAll<HTMLElement>(`.ph[data-kategori="${kategori}"]`)
      ).filter(e => e.dataset.src)

      const photoList = siblings.map(e => ({
        src: e.dataset.src!,
        alt: e.dataset.alt || ''
      }))

      const clickedIndex = siblings.indexOf(el)
      openAt(photoList, Math.max(0, clickedIndex))
    })
  })
</script>
