---
import Base from '../layouts/Base.astro';
import StatsBar from '../components/fasilitas/StatsBar.astro';
import FeatGrid from '../components/fasilitas/FeatGrid.astro';
import FeatList from '../components/fasilitas/FeatList.astro';
import PullQuote from '../components/fasilitas/PullQuote.astro';
import TransportGrid from '../components/fasilitas/TransportGrid.astro';
import RulesGrid from '../components/fasilitas/RulesGrid.astro';
import CtaBand from '../components/ui/CtaBand.astro';

import kamarFeats from '../content/fasilitas/kamar.json';
import bersamaFeats from '../content/fasilitas/bersama.json';
---
<Base
  title="Fasilitas Wisma 52 — Lengkap, Sudah Termasuk Semua"
  description="Fasilitas kosan Wisma 52: AC, kamar mandi dalam, WiFi, listrik termasuk, parkir gratis, CCTV 24 jam, dapur per lantai. Lokasi strategis Kramat Raya, Jakarta Pusat."
  path="/fasilitas"
>
  <!-- Page header -->
  <div class="page-header">
    <div class="breadcrumb">Beranda <span>›</span> Fasilitas</div>
    <h1 class="page-title serif">Fasilitas<br>yang worth it.</h1>
    <p class="page-sub">
      Bukan sekadar daftar icon. Ini alasan konkret kenapa harga sewa Wisma 52 masuk akal
      — bahkan murah, kalau dihitung semua yang sudah termasuk.
    </p>
  </div>

  <!-- Stats bar: 0 biaya · 24 jam · 5+ lantai -->
  <StatsBar />

  <!-- Di dalam kamar -->
  <section class="section">
    <p class="section-label">Di dalam kamar</p>
    <FeatGrid
      layout="duo"
      main={{ title: 'Kamar mandi dalam', sub: 'Kloset duduk · shower · water heater', color: '#a8a49a', aspect: 'tall' }}
      stack={[
        { title: 'AC', sub: 'Dingin seharian', color: '#b8b4aa', aspect: 'square' },
        { title: 'Spring bed & lemari', sub: 'Lengkap siap huni', color: '#c4c0b6', aspect: 'square' },
      ]}
    />
    <FeatList items={kamarFeats} />
  </section>

  <!-- Pull quote divider -->
  <PullQuote text='"Di Jakarta Pusat, <em>parkir gratis dan listrik termasuk</em> itu bukan standar — itu privilege."' />

  <!-- Fasilitas bersama -->
  <section class="section">
    <p class="section-label">Fasilitas bersama</p>
    <FeatGrid
      layout="trio"
      main={{ title: 'Dapur per lantai', sub: 'Kompor, dispenser, kulkas', color: '#b0aca2', aspect: 'free', minHeight: 140 }}
      stack={[
        { title: 'Musholla', color: '#bab6ac', aspect: 'free', minHeight: 68, titleSm: true },
        { title: 'Ruang tamu', color: '#c8c4ba', aspect: 'free', minHeight: 68, titleSm: true },
      ]}
    />
    <FeatList items={bersamaFeats} />
  </section>

  <!-- Transport & lokasi -->
  <TransportGrid />

  <!-- Peraturan -->
  <RulesGrid />

  <!-- CTA -->
  <CtaBand
    title="Mau lihat langsung?"
    subtitle="Jadwalkan survei, tidak ada kewajiban bayar sebelum puas."
    primaryLabel="Jadwalkan survei"
    primaryHref="https://wa.me/6281383667680?text=Halo%2C+saya+ingin+jadwalkan+survei+kamar+Wisma52"
    secondaryLabel="Lihat tipe kamar"
    secondaryHref="/kamar"
    secondaryVariant="ghost-border"
  />
</Base>
