---
import Base from '../layouts/Base.astro';
import AvailabilityBar from '../components/kamar/AvailabilityBar.astro';
import RoomCards from '../components/kamar/RoomCards.astro';
import PromoBanner from '../components/kamar/PromoBanner.astro';
import CompareTable from '../components/kamar/CompareTable.astro';
import IncludedGrid from '../components/kamar/IncludedGrid.astro';
import BookingSteps from '../components/kamar/BookingSteps.astro';
import CtaBand from '../components/ui/CtaBand.astro';
---
<Base
  title="Kamar & Harga Sewa — Wisma 52 Jakarta Pusat"
  description="Kamar Standard Rp 2,95jt dan Deluxe Rp 3,2jt per bulan. Semua sudah termasuk listrik, WiFi, AC, kamar mandi dalam, parkir gratis. Kramat Raya, Jakarta Pusat."
  path="/kamar"
>
  <!-- Page header -->
  <div class="section-full section-cream">
    <div class="container">
      <div class="page-header">
        <div class="breadcrumb">Beranda <span>›</span> Kamar &amp; Harga</div>
        <h1 class="page-title serif">Kamar &amp;<br />harga sewa.</h1>
        <p class="page-sub">
          Dua tipe kamar, semua sudah termasuk listrik, WiFi, dan fasilitas lengkap.
          Tidak ada biaya tersembunyi.
        </p>
      </div>
    </div>
  </div>

  <!-- Availability bar -->
  <AvailabilityBar count={5} note="Diperbarui hari ini." />

  <!-- Room cards -->
  <RoomCards />

  <!-- Promo banner -->
  <PromoBanner />

  <!-- Compare table -->
  <CompareTable />

  <!-- Included features -->
  <IncludedGrid />

  <!-- Booking steps -->
  <BookingSteps />

  <!-- CTA -->
  <CtaBand
    title="Ada yang mau ditanyakan?"
    subtitle="Admin responsif, balas dalam hitungan menit."
    primaryLabel="Chat WhatsApp sekarang"
    primaryHref="https://wa.me/6281383667680?text=Halo%2C+saya+ingin+tanya+info+kamar+Wisma+52"
    secondaryLabel="Lihat galeri foto"
    secondaryHref="/galeri"
    secondaryVariant="ghost-border"
  />

  <!-- Room photo lightbox (shared, single instance) -->
  <div id="room-lightbox" class="lightbox" aria-hidden="true">
    <button class="lightbox-close" id="room-lightbox-close" aria-label="Tutup">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <div class="lightbox-backdrop" id="room-lightbox-backdrop"></div>
    <div class="lightbox-content" style="position:relative;z-index:1">
      <button id="room-lb-prev"
        style="position:fixed;left:20px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.15);border:none;color:#fff;width:44px;height:44px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:2">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>
      <img id="room-lb-img" src="" alt=""
        style="max-width:88vw;max-height:80vh;object-fit:contain;display:block;position:relative;z-index:1"
      />
      <button id="room-lb-next"
        style="position:fixed;right:20px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.15);border:none;color:#fff;width:44px;height:44px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:2">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>
      <div style="text-align:center;margin-top:12px;position:relative;z-index:1">
        <p id="room-lb-caption" style="color:rgba(255,255,255,0.7);font-size:13px;margin-bottom:6px"></p>
        <p id="room-lb-counter" style="color:rgba(255,255,255,0.4);font-size:12px"></p>
      </div>
      <div id="room-lb-thumbs" style="display:flex;gap:8px;margin-top:16px;position:relative;z-index:1"></div>
    </div>
  </div>

  <script>
    const lightbox = document.getElementById('room-lightbox')
    const lbImg = document.getElementById('room-lb-img') as HTMLImageElement | null
    const lbCaption = document.getElementById('room-lb-caption')
    const lbCounter = document.getElementById('room-lb-counter')
    const lbThumbs = document.getElementById('room-lb-thumbs')
    const lbPrev = document.getElementById('room-lb-prev') as HTMLButtonElement | null
    const lbNext = document.getElementById('room-lb-next') as HTMLButtonElement | null
    const lbClose = document.getElementById('room-lightbox-close')
    const lbBackdrop = document.getElementById('room-lightbox-backdrop')

    type Photo = { src: string; alt: string }
    let photos: Photo[] = []
    let currentIndex = 0

    function goTo(index: number) {
      currentIndex = Math.max(0, Math.min(index, photos.length - 1))
      const photo = photos[currentIndex]
      if (lbImg) { lbImg.src = photo.src; lbImg.alt = photo.alt }
      if (lbCaption) lbCaption.textContent = photo.alt
      if (lbCounter) lbCounter.textContent = `${currentIndex + 1} / ${photos.length}`
      if (lbPrev) lbPrev.style.opacity = currentIndex === 0 ? '0.3' : '1'
      if (lbNext) lbNext.style.opacity = currentIndex === photos.length - 1 ? '0.3' : '1'
      document.querySelectorAll<HTMLImageElement>('#room-lb-thumbs img').forEach((t, i) => {
        t.style.opacity = i === currentIndex ? '1' : '0.5'
        t.style.border = i === currentIndex ? '2px solid #fff' : '2px solid transparent'
      })
    }

    function openLightbox(photoList: Photo[], startIndex = 0) {
      photos = photoList
      if (lbThumbs) {
        lbThumbs.innerHTML = ''
        photos.forEach((p, i) => {
          const thumb = document.createElement('img')
          thumb.src = p.src
          thumb.alt = p.alt
          thumb.style.cssText = `width:56px;height:42px;object-fit:cover;cursor:pointer;transition:opacity 0.2s`
          thumb.addEventListener('click', () => goTo(i))
          lbThumbs.appendChild(thumb)
        })
      }
      goTo(startIndex)
      lightbox?.classList.add('open')
      lightbox?.setAttribute('aria-hidden', 'false')
      document.body.style.overflow = 'hidden'
    }

    const closeLightbox = () => {
      lightbox?.classList.remove('open')
      lightbox?.setAttribute('aria-hidden', 'true')
      document.body.style.overflow = ''
      photos = []
    }

    lbPrev?.addEventListener('click', () => goTo(currentIndex - 1))
    lbNext?.addEventListener('click', () => goTo(currentIndex + 1))
    lbClose?.addEventListener('click', closeLightbox)
    lbBackdrop?.addEventListener('click', closeLightbox)

    document.addEventListener('keydown', e => {
      if (!lightbox?.classList.contains('open')) return
      if (e.key === 'ArrowLeft') goTo(currentIndex - 1)
      if (e.key === 'ArrowRight') goTo(currentIndex + 1)
      if (e.key === 'Escape') closeLightbox()
    })

    document.querySelectorAll<HTMLElement>('.tipe-img').forEach(trigger => {
      trigger.addEventListener('click', () => {
        const dataEl = trigger.querySelector('.room-photos-data')
        if (!dataEl) return
        try {
          const photoList = JSON.parse(dataEl.textContent || '[]') as Photo[]
          openLightbox(photoList, 0)
        } catch(e) { console.error(e) }
      })
    })
  </script>
</Base>
