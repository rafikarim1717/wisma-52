---
import SeoHead from '../components/seo/SeoHead.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import WaButton from '../components/layout/WaButton.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  path?: string;
  preloadImage?: string;
}

const { title, description, path, preloadImage } = Astro.props;
---
<!doctype html>
<html lang="id" style="margin:0;padding:0">
  <head>

    <SeoHead title={title} description={description} path={path} preloadImage={preloadImage} />
    
    <meta name="google-site-verification" content="gPB6avBic13s0_AZvvy5EbqTUgEOmpxIJvAlYu8mLdc" />
    
    <slot name="head" />
  </head>
  <body style="margin:0;padding:0;min-height:100vh">
    <Navbar />
    <slot />
    <Footer />
    <WaButton />
  </body>
  <script is:inline>
    (function() {
      function loadGA() {
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-2JMFQ54TTE';
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        window.gtag = function(){ window.dataLayer.push(arguments); };
        window.gtag('js', new Date());
        window.gtag('config', 'G-2JMFQ54TTE');
      }
      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadGA, { timeout: 3000 });
      } else {
        setTimeout(loadGA, 2000);
      }
    })();
  </script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const page = window.location.pathname || '/'
      const pageNames: Record<string, string> = {
        '/': 'homepage',
        '/kamar': 'kamar',
        '/fasilitas': 'fasilitas',
        '/lokasi': 'lokasi',
        '/galeri': 'galeri',
      }
      const pageName = pageNames[page] || page.replace('/', '') || 'homepage'

      document.querySelectorAll<HTMLAnchorElement>('a[href*="wa.me"]').forEach(link => {
        link.addEventListener('click', () => {
          // Sekarang gtag sudah aman dipanggil karena sudah didefinisikan di <head>
          if (typeof (window as any).gtag !== 'undefined') {
            ;(window as any).gtag('event', 'whatsapp_click', {
              event_category: 'conversion',
              event_label: pageName,
              page_location: window.location.href,
            })
          }
        })
      })
    })
  </script>
</html>